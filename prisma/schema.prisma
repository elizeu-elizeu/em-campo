generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite não tem enum — papéis/tipos/status são strings validadas na aplicação.

model User {
  id           Int           @id @default(autoincrement())
  nome         String
  email        String        @unique
  senha        String // hash bcrypt
  papel        String // TECNICO | GESTOR
  ativo        Boolean       @default(true)
  relatorios   Relatorio[]
  agendamentos Agendamento[]
  eventos      Evento[]
}

// Dados da prestadora — linha única (id=1), aparece no cabeçalho dos relatórios.
model Empresa {
  id       Int     @id @default(1)
  nome     String
  cnpj     String?
  telefone String?
  email    String?
  endereco String?
  logo     String? // arquivo em uploads/ (nome uuid.ext), servido por /uploads/[nome]
}

// Parametrizações do app — linha única (id=1).
model Config {
  id              Int     @id @default(1)
  usarNomeEmpresa Boolean @default(true) // app do técnico exibe o nome da empresa no lugar de "EmCampo"
  exigirFoto      Boolean @default(false) // todo relatório precisa de ao menos 1 foto para ser enviado
}

model Cliente {
  id           Int           @id @default(autoincrement())
  nome         String
  endereco     String?
  contato      String?
  relatorios   Relatorio[]
  agendamentos Agendamento[]
}

model Modelo {
  id           Int           @id @default(autoincrement())
  nome         String
  ativo        Boolean       @default(true)
  campos       Campo[]
  relatorios   Relatorio[]
  agendamentos Agendamento[]
}

// Serviço agendado pelo gestor — vira relatório quando o técnico atende.
model Agendamento {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  modeloId      Int
  modelo        Modelo   @relation(fields: [modeloId], references: [id])
  tecnicoId     Int
  tecnico       User     @relation(fields: [tecnicoId], references: [id])
  data          DateTime
  observacao    String?
  status        String   @default("ABERTO") // ABERTO | CONCLUIDO | CANCELADO
  relatorioUuid String?  @unique // preenchido quando o relatório do atendimento sincroniza
}

// Trilha de auditoria: quem fez o quê e quando (exigência comum em contrato B2B).
model Evento {
  id     Int      @id @default(autoincrement())
  quando DateTime @default(now())
  userId Int
  user   User     @relation(fields: [userId], references: [id])
  acao   String
  alvo   String?
}

model Campo {
  id          Int     @id @default(autoincrement())
  modeloId    Int
  modelo      Modelo  @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  ordem       Int
  tipo        String // TEXTO_CURTO | TEXTO_LONGO | NUMERO | SIM_NAO | ESCOLHA | FOTO | ASSINATURA
  rotulo      String
  obrigatorio Boolean @default(false)
  opcoes      String? // JSON string[] — só para tipo ESCOLHA
  multipla    Boolean @default(false) // ESCOLHA: permite marcar várias opções
  noCabecalho Boolean @default(false) // valor sobe para o cabeçalho do relatório/PDF
}

model Relatorio {
  uuid            String   @id // gerado no cliente — torna o sync idempotente
  modeloId        Int
  modelo          Modelo   @relation(fields: [modeloId], references: [id])
  tecnicoId       Int
  tecnico         User     @relation(fields: [tecnicoId], references: [id])
  clienteId       Int
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  data            DateTime @default(now())
  status          String   @default("ENVIADO") // ENVIADO | DEVOLVIDO | APROVADO
  comentarioGestor String?
  // Snapshot autocontido [{campoId, rotulo, tipo, valor}] — imune a edições do modelo
  respostas       String   @default("[]")
  // Token do link público compartilhável (null = não compartilhado)
  linkPublico     String?  @unique
  fotos           Foto[]
}

model Foto {
  uuid          String    @id // gerado no cliente — reenvio de upload é idempotente
  relatorioUuid String
  relatorio     Relatorio @relation(fields: [relatorioUuid], references: [uuid], onDelete: Cascade)
  campoId       Int? // null = foto avulsa do relatório
  arquivo       String // nome do arquivo em uploads/ (fora de public/ — acesso só via /uploads/[nome])
  legenda       String?
}
